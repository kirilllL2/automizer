```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# Build/dist directories
dist/
build/
target/

# Dependencies
node_modules/
.mypy_cache/
.pytest_cache/
.coverage
coverage/
htmlcov/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
```