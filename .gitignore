```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
.venv/
venv/
env/

# Build/dist directories
build/
dist/
*.egg-info/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Coverage reports
.coverage
coverage/
htmlcov/

# Testing
.pytest_cache/
.mypy_cache/

# OS generated files
.DS_Store
Thumbs.db
```