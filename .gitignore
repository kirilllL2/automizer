```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
env/

# Logs
*.log

# Temporary files
*.tmp
*.swp

# IDE specific
.vscode/
.idea/

# Environment files
.env
.env.local
*.env.*

# Coverage reports
.coverage
coverage/
htmlcov/

# Build artifacts
dist/
build/
target/

# Package manager cache
node_modules/
.npm/
.yarn/
.pnpm/

# OS generated files
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.mypy_cache/
```